# Database
DATABASE_URL="postgresql://user:password@host:26257/masssafe?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
