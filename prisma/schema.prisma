// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedLocations SavedLocation[]

  @@map("users")
}

model City {
  id           String  @id @default(cuid())
  jurisdiction String  @unique // URL slug identifier (e.g., "boston", "worcester")
  name         String  // Display name (e.g., "Boston", "Worcester")
  url          String  // Source URL from MA crime portal
  year         String  // Data year (e.g., "2024")
  
  // Crime statistics
  crimesTotal         Int
  crimesClearanceRate Float?
  
  // Population and rates
  population Int
  crimeRate  Float?
  
  // Arrest statistics
  arrestsTotal Int
  arrestRate   Float?
  
  // Data quality flag
  success Boolean @default(true)
  
  // Legacy fields (optional, for backward compatibility)
  county              String?
  latitude            Float?
  longitude           Float?
  state               String  @default("Massachusetts")
  type                String?
  government          String?
  area_total_sq_mi    Float?
  area_land_sq_mi     Float?
  year_incorporated   Int?

  savedLocations SavedLocation[]
  crimeCache     CrimeCache[]

  @@index([name])
  @@index([jurisdiction])
  @@map("cities")
}

model SavedLocation {
  id          String   @id @default(cuid())
  userId      String
  cityId      String
  safetyScore Float?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([userId])
  @@map("saved_locations")
}

model CrimeCache {
  id            String   @id @default(cuid())
  cityId        String
  violentCrime  Int
  propertyCrime Int
  year          Int
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, year])
  @@index([cityId])
  @@map("crime_cache")
}
